# Groq API key (only needed if you use the "AI (Groq LLM)" engine)
GROQ_API_KEY=your_groq_api_key_here

# Current, supported Groq model.
# NOTE: llama-3.1-70b-versatile is DECOMMISSIONED and llama-3.3-70b-versatile
# is scheduled for shutdown on 2026-08-16. Use a current model instead.
GROQ_MODEL=openai/gpt-oss-120b
